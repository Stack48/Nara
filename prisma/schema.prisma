generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD_LYRICIST
  LYRICIST
  READONLY
}

enum SectionType {
  COUPLET
  REFRAIN
  PONT
  INTRO
  OUTRO
  BRIDGE
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum LyricsState {
  DRAFT
  IN_PROGRESS
  COMPLETED
  REVIEW
}

model User {
  id             String   @id @default(cuid())
  cognitoId      String   @unique @default("")
  email          String   @unique
  name           String?
  username       String?  @unique
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships    ProjectMember[]
  invitations    Invitation[]
  ownedProjects  Project[]            @relation("OwnedProjects")
  lyrics         Lyrics[]
  suggestions    Suggestion[]
  lyricVersions  LyricVersion[]
  files          File[]
  auditLogs      AuditLog[]
  markers        AudioMarker[]
  passwordResets PasswordResetRequest[]
  comments       Comment[]
  authorshipCertificates AuthorshipCertificate[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  genre       String?
  status      ProjectStatus @default(DRAFT)
  imageUrl    String?
  isFavorite  Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  ownerId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner       User            @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  invitations Invitation[]
  lyrics      Lyrics[]
  files       File[]
  labelCopies LabelCopy[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      Role     @default(LYRICIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role     @default(LYRICIST)
  token     String   @unique @default(cuid())
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  projectId String
  invitedBy String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter   User    @relation(fields: [invitedBy], references: [id])
}

model Lyrics {
  id          String      @id @default(cuid())
  title       String
  content     Json
  order       Int         @default(0)
  sectionType SectionType @default(COUPLET)
  state       LyricsState @default(DRAFT)
  imageUrl    String?
  audioSrc    String?
  isFavorite  Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?
  projectId   String?
  authorId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User           @relation(fields: [authorId], references: [id])
  suggestions Suggestion[]
  versions    LyricVersion[]
  markers     AudioMarker[]
  comments    Comment[]
  authorshipCertificates AuthorshipCertificate[]
}

model Suggestion {
  id        String           @id @default(cuid())
  content   Json
  status    SuggestionStatus @default(PENDING)
  lyricsId  String
  authorId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  lyrics    Lyrics @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id])
}

model LyricVersion {
  id        String   @id @default(cuid())
  content   Json
  version   Int
  lyricsId  String
  authorId  String
  createdAt DateTime @default(now())

  lyrics    Lyrics @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  lyricsId  String
  authorId  String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lyrics    Lyrics @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id])
}

model File {
  id           String   @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  s3Key        String   @unique
  projectId    String
  uploadedBy   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader     User          @relation(fields: [uploadedBy], references: [id])
  markers      AudioMarker[]
}

model AudioMarker {
  id        String   @id @default(cuid())
  timecode  Float
  label     String?
  lyricsId  String
  fileId    String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lyrics    Lyrics   @relation(fields: [lyricsId], references: [id], onDelete: Cascade)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id])
}

model LabelCopy {
  id            String    @id @default(cuid())
  title         String
  isrc          String?
  composers     String[]
  publishers    String[]
  recordLabel   String?
  releaseDate   DateTime?
  projectId     String
  bridgeAudioId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Certificat d'auteur (coffre « Mes contributions » du ghostwriter).
// Chaque scellement crée une VERSION immuable : empreinte SHA-256 canonique du
// contenu écrit + horodatage. Le certificat appartient à l'AUTEUR et survit à la
// suppression du projet (lyricsId onDelete: SetNull) — c'est tout l'objet de la
// protection du ghostwriter.
model AuthorshipCertificate {
  id                    String   @id @default(cuid())
  version               Int
  contentHashHex        String
  canonicalSnapshot     Json
  projectRef            String
  title                 String
  tsaName               String
  qualified             Boolean  @default(false)
  tsrB64                String   @default("")
  sealedAt              DateTime
  confidentialityNotice String

  lyricsId              String?
  authorId              String
  lyrics                Lyrics?  @relation(fields: [lyricsId], references: [id], onDelete: SetNull)
  author                User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())

  @@unique([authorId, projectRef, version])
  @@index([authorId])
  @@index([lyricsId])
}

model PasswordResetRequest {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}